# ScheduleBox Environment Variables
# Copy to .env and customize for your setup

# ============================================================================
# Required for production (app will not start without these)
# ============================================================================

# Application
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon PostgreSQL — serverless)
# Neon pooled connection for runtime queries
DATABASE_URL=postgresql://schedulebox:schedulebox@localhost:5432/schedulebox
# Neon direct connection for migrations (no pooler)
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/schedulebox
# POSTGRES_PASSWORD is used by docker-compose.prod.yml for the postgres container
POSTGRES_PASSWORD=schedulebox

# Upstash Redis (serverless HTTP)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Authentication — MUST be at least 16 characters in production
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# ============================================================================
# Optional / has defaults
# ============================================================================

# Application version
APP_VERSION=1.0.0

# JWT token expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Timezone
TZ=Europe/Prague

# ===================
# Database (additional connection params — used by some scripts)
# ===================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=schedulebox
DATABASE_PASSWORD=schedulebox
DATABASE_NAME=schedulebox

# ============================================================================
# Payment Gateways
# ============================================================================

# Comgate (Czech online card payment gateway)
COMGATE_MERCHANT_ID=your-merchant-id-here
COMGATE_SECRET=your-secret-key-here
COMGATE_API_URL=https://payments.comgate.cz
COMGATE_TEST_MODE=true
COMGATE_RECURRING_ENABLED=false

# Payment timeout (minutes until pending payment expires)
PAYMENT_TIMEOUT_MINUTES=30

# Cron endpoint authentication (used by Railway Cron to call expire-pending)
CRON_SECRET=generate-a-random-secret-here

# Company default IBAN for QR payments (optional, can be set per-company in settings)
COMPANY_DEFAULT_IBAN=CZ6508000000192000145399

# ============================================================================
# Notifications
# ============================================================================

# SMTP Email — Cesky Hosting (https://www.cesky-hosting.cz)
# SMTP_USER = full email address (e.g., no-reply@schedulebox.cz)
SMTP_HOST=smtp.cesky-hosting.cz
SMTP_PORT=587
SMTP_USER=no-reply@schedulebox.cz
SMTP_PASS=your-smtp-password-here
SMTP_FROM=no-reply@schedulebox.cz

# Twilio SMS Configuration
# Get credentials from: https://console.twilio.com/ -> Account Info
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Czech mobile number purchased from Twilio (E.164 format, e.g., +420601234567)
TWILIO_FROM_NUMBER=+420XXXXXXXXX
# OR use Twilio Messaging Service SID (alternative to FROM_NUMBER)
TWILIO_MESSAGING_SERVICE_SID=

# SMS Cost Optimization
# AI no-show score threshold for SMS gating (default: 0.7 = only high-risk bookings)
SMS_NO_SHOW_THRESHOLD=0.7
# Monthly SMS budget alert threshold in USD (default: 50)
SMS_BUDGET_ALERT_THRESHOLD=50
# Per-segment cost in CZK for SMS monitoring
SMS_COST_PER_SEGMENT_CZK=0.50
# Monthly SMS cost limit in CZK
SMS_MONTHLY_COST_LIMIT_CZK=500

# Web Push VAPID Keys (required for push notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ============================================================================
# AI Service
# ============================================================================
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_PORT=8000
AI_MODEL_DIR=./services/ai/models

# OpenAI API key for Whisper STT and GPT-4 (required for voice/follow-up features)
OPENAI_API_KEY=
# GPT model for voice intent extraction (default: gpt-4-turbo)
OPENAI_MODEL=gpt-4-turbo
# GPT model for follow-up generation (default: gpt-4o-mini, 10x cheaper)
OPENAI_FOLLOWUP_MODEL=gpt-4o-mini
# Google Places API key for competitor review data (optional)
GOOGLE_PLACES_API_KEY=
# Max audio file size in MB for voice booking (default: 10)
MAX_AUDIO_SIZE_MB=10
# Max follow-up generations per company per day (default: 50)
MAX_FOLLOWUP_PER_DAY=50
# Max competitors monitored per company (default: 5)
MAX_COMPETITORS_PER_COMPANY=5

# ============================================================================
# Platform / Invoice Generation
# ============================================================================
PLATFORM_COMPANY_NAME=ScheduleBox s.r.o.
PLATFORM_ICO=
PLATFORM_DIC=
PLATFORM_ADDRESS=

# ============================================================================
# OpenTelemetry Sampling (10% trace rate for production)
# Set these in Vercel project settings → Environment Variables
# ============================================================================
# Sampler type: parentbased_traceidratio honours parent-set sampling decisions
OTEL_TRACES_SAMPLER=parentbased_traceidratio
# 0.1 = 10% of root spans will be sampled (edge + nodejs runtimes)
OTEL_TRACES_SAMPLER_ARG=0.1
