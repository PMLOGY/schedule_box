{
  "uid": "schedulebox-overview",
  "title": "ScheduleBox Overview",
  "tags": ["schedulebox", "production"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "type": "row",
      "title": "HTTP Performance"
    },
    {
      "id": 2,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "type": "timeseries",
      "title": "Request Rate",
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "type": "timeseries",
      "title": "p95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 2, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "type": "stat",
      "title": "Error Rate",
      "targets": [
        {
          "expr": "rate(http_requests_total{status_code=~\"5..\"}[5m]) / rate(http_requests_total[5m])",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 5,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "type": "row",
      "title": "Node.js Runtime"
    },
    {
      "id": 6,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "type": "gauge",
      "title": "Event Loop Utilization",
      "targets": [
        {
          "expr": "nodejs_eventloop_utilization",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.5, "color": "yellow" },
              { "value": 0.7, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 7,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "type": "timeseries",
      "title": "Heap Used",
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "type": "timeseries",
      "title": "Active Handles",
      "targets": [
        {
          "expr": "nodejs_active_handles_total",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 9,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "type": "row",
      "title": "Business Metrics"
    },
    {
      "id": 10,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "type": "timeseries",
      "title": "Bookings per Minute",
      "targets": [
        {
          "expr": "rate(schedulebox_bookings_total[5m]) * 60",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 11,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "type": "piechart",
      "title": "Payments by Gateway",
      "targets": [
        {
          "expr": "sum by(gateway) (rate(schedulebox_payments_total[5m]))",
          "legendFormat": "{{gateway}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "pieType": "pie",
        "displayLabels": ["percent"]
      }
    },
    {
      "id": 12,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "type": "timeseries",
      "title": "AI Prediction Latency (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(schedulebox_ai_prediction_duration_seconds_bucket[5m]))",
          "legendFormat": "{{model_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 13,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "type": "row",
      "title": "Infrastructure"
    },
    {
      "id": 14,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "type": "timeseries",
      "title": "Pod CPU Usage",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"production\",pod=~\"schedulebox-.*\"}[5m])",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 15,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "type": "timeseries",
      "title": "Pod Memory Usage",
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"production\",pod=~\"schedulebox-.*\"}",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 16,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "type": "gauge",
      "title": "DB Connections",
      "targets": [
        {
          "expr": "pg_connections_active",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 10,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 8, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
