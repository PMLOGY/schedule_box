{
  "name": "@schedulebox/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "default": "./src/schemas/index.ts"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "default": "./src/utils/index.ts"
    },
    "./video-providers": {
      "types": "./src/video-providers/index.ts",
      "default": "./src/video-providers/index.ts"
    },
    "./metrics": {
      "types": "./src/metrics/index.ts",
      "default": "./src/metrics/index.ts"
    },
    "./metrics/event-loop": {
      "types": "./src/metrics/event-loop.ts",
      "default": "./src/metrics/event-loop.ts"
    },
    "./metrics/business": {
      "types": "./src/metrics/business.ts",
      "default": "./src/metrics/business.ts"
    },
    "./logger": {
      "types": "./src/logger/index.ts",
      "default": "./src/logger/index.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.211.0",
    "@opentelemetry/instrumentation-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0",
    "zod": "^3.23.0"
  }
}
